@page
@model IndexModel
@{
    ViewData["Title"] = "Zoo Visitors App";
}

<h1>Welcome to the Zoo Visitors App</h1>

<form method="post">
    <!-- Form inputs for selecting animal hunger level and day of the week -->
    
    <label>Enter the animal's hunger level (1-10):</label>  
    <input type="number" name="hungerLevel" min="1" max="10"/> 
    
    <br><br>
    <label>Enter the day of the week (1-7, where 1 is Sunday): </label>
    <input type="number" name="dayOfWeek" min="1" max="7"/>
    
    <br><br>

    <button type="submit">Submit</button>
    
</form>

<!-- Display the hunger, sound, and day messages only when they have been populated -->
@if (!string.IsNullOrEmpty(Model.HungerMessage))
{
    <hr />
    <p>@Model.HungerMessage</p>
    <p>@Model.SoundMessage</p>
    <p>@Model.DayMessage</p>
}

